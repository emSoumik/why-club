---
import OrderHistoryPanel from "@/components/account/OrderHistoryPanel";
import StorefrontLayout from "@/layouts/StorefrontLayout.astro";
import { demoProducts } from "@/lib/demo-data";
---

<StorefrontLayout title="WhÿClub | account orders">
  <section class="store-shell mx-auto max-w-7xl px-4 py-12 md:px-6 md:py-16">
    <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
      <article class="rounded-[2rem] border border-black bg-white p-8 md:p-10">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-red-600">account</p>
        <h1 class="mt-4 text-4xl font-black uppercase leading-[0.88] tracking-[-0.06em] text-black md:text-6xl">
          Your orders, without the noise.
        </h1>
        <p class="mt-5 max-w-2xl text-sm leading-8 text-neutral-600">
          This page falls back to seeded demo history locally, but once Convex is
          configured it reads customer-specific orders directly from the backend
          using the same captured and fulfilment states used everywhere else.
        </p>

        <OrderHistoryPanel client:load demoProducts={demoProducts} />
      </article>

      <aside class="rounded-[2rem] border border-black bg-black p-8 text-white md:p-10">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-red-400">account routes</p>
        <div class="mt-6 grid gap-4">
          <a href="/account" class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
            <h2 class="text-xl font-black uppercase tracking-[0.04em]">overview</h2>
            <p class="mt-3 text-sm leading-7 text-neutral-400">
              Return to the main account surface for auth state and quick actions.
            </p>
          </a>
          <a href="/checkout" class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
            <h2 class="text-xl font-black uppercase tracking-[0.04em]">checkout</h2>
            <p class="mt-3 text-sm leading-7 text-neutral-400">
              Move straight into the live or demo payment workflow.
            </p>
          </a>
          <a href="/cart" class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
            <h2 class="text-xl font-black uppercase tracking-[0.04em]">cart</h2>
            <p class="mt-3 text-sm leading-7 text-neutral-400">
              Rebalance quantities before you open another order.
            </p>
          </a>
        </div>
      </aside>
    </div>
  </section>
</StorefrontLayout>
