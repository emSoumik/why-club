---
import StorefrontLayout from "@/layouts/StorefrontLayout.astro";
import { demoProducts, siteCopy } from "@/lib/demo-data";
---

<StorefrontLayout title="WhÿClub | story" description="The WhyClub brand story and product point of view.">
  <section class="store-shell mx-auto max-w-7xl px-4 py-12 md:px-6 md:py-16">
    <div class="grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
      <article class="rounded-[2rem] border border-black bg-black p-8 text-white">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-red-400">our story</p>
        <h1 class="mt-4 text-5xl font-black uppercase leading-[0.86] tracking-[-0.07em] md:text-7xl">
          We started because everything else felt the same.
        </h1>
        <p class="mt-6 text-base leading-8 text-neutral-300">
          WhÿClub did not start with a trend deck. It started with the feeling that
          every tee on the market looked safe. So the brand direction became simple:
          fewer products, more intent, and graphics that actually say something.
        </p>
      </article>
      <div class="grid gap-4">
        <div class="overflow-hidden rounded-[2rem] border border-black">
          <img src={demoProducts[0].images[0]} alt={demoProducts[0].title} class="aspect-[4/3] w-full object-cover object-top" />
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <article class="rounded-[2rem] border border-black bg-white p-6">
            <p class="text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-neutral-500">origin</p>
            <p class="mt-4 text-4xl font-black uppercase tracking-[-0.05em] text-black">{siteCopy.originCity}</p>
            <p class="mt-3 text-sm leading-7 text-neutral-600">The city that gave the brand its first late-night references and its first real customers.</p>
          </article>
          <article class="rounded-[2rem] border border-black bg-white p-6">
            <p class="text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-neutral-500">point of view</p>
            <p class="mt-4 text-sm leading-7 text-neutral-600">
              Feelings, not briefs. Community over clout. Streetwear that feels local and specific instead of imported by moodboard.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="store-shell mx-auto max-w-7xl px-4 pb-16 md:px-6">
    <div class="grid gap-4 md:grid-cols-3">
      {
        demoProducts.map((product) => (
          <article class="rounded-[2rem] border border-black bg-white p-5">
            <img src={product.images[0]} alt={product.title} class="aspect-[4/5] w-full rounded-[1.5rem] border border-black object-cover object-top" />
            <h2 class="mt-5 text-2xl font-black uppercase tracking-[-0.05em] text-black">{product.title}</h2>
            <p class="mt-3 text-sm leading-7 text-neutral-600">{product.story}</p>
          </article>
        ))
      }
    </div>
  </section>
</StorefrontLayout>
