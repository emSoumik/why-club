---
import ProductCard from "@/components/storefront/ProductCard.astro";
import SectionHeader from "@/components/storefront/SectionHeader.astro";
import StorefrontLayout from "@/layouts/StorefrontLayout.astro";
import { demoCollections, demoProducts, getProductsByCollection } from "@/lib/demo-data";
---

<StorefrontLayout
  title="WhÿClub | collections"
  description="Browse the current WhyClub drop and the full oversized tee lineup."
>
  <section class="store-shell mx-auto max-w-7xl px-4 py-12 md:px-6 md:py-16">
    <SectionHeader
      eyebrow="collections"
      title="Built like drops, not an endless feed."
      body="The assortment stays narrow on purpose so each product still feels like a release instead of inventory wallpaper."
    />
    <div class="mt-8 grid gap-4">
      {
        demoCollections.map((collection) => (
          <article class="overflow-hidden rounded-[2rem] border border-black bg-white">
            <div class="grid gap-0 md:grid-cols-[0.85fr_1.15fr]">
              <img src={collection.imageUrl} alt={collection.title} class="h-full min-h-[22rem] w-full object-cover object-top" />
              <div class="flex flex-col justify-between p-6 md:p-8">
                <div>
                  <p class="text-[0.62rem] font-semibold uppercase tracking-[0.32em] text-red-600">live now</p>
                  <h2 class="mt-3 text-4xl font-black uppercase tracking-[-0.06em] text-black md:text-6xl">{collection.title}</h2>
                  <p class="mt-4 max-w-xl text-sm leading-8 text-neutral-600">{collection.description}</p>
                </div>
                <div class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-black pt-4">
                  <span class="text-[0.62rem] font-semibold uppercase tracking-[0.28em] text-neutral-500">
                    {getProductsByCollection(collection.slug).length} products
                  </span>
                  <a href={`/collections/${collection.slug}`} class="store-btn store-btn--dark">
                    open collection
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="store-shell mx-auto max-w-7xl px-4 pb-16 md:px-6">
    <SectionHeader
      eyebrow="shop all"
      title="The current catalog."
      body="All storefront cards are Astro-rendered against the demo dataset, ready to swap to Convex-backed queries later without changing the visual structure."
    />
    <div class="mt-8 grid gap-px overflow-hidden border border-black bg-black md:grid-cols-3">
      {demoProducts.map((product) => (
        <div class="bg-white">
          <ProductCard product={product} />
        </div>
      ))}
    </div>
  </section>
</StorefrontLayout>
