---
import AdminTable from "@/components/admin/AdminTable.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";

const orders = [
  ["WC-24031", "Paid", "Razorpay", "Bengaluru", "Ready for dispatch"],
  ["WC-24026", "Processing", "COD", "Delhi", "Awaiting shipment"],
  ["WC-24018", "Delivered", "Prepaid", "Mumbai", "Completed"],
];
---

<AdminLayout title="WhÿClub admin | orders">
  <div class="space-y-8">
    <header class="space-y-3">
      <p class="text-[0.68rem] uppercase tracking-[0.35em] text-neutral-500">orders</p>
      <h1 class="font-display text-6xl leading-[0.9] tracking-[-0.09em] text-neutral-950">Fulfilment in one pass.</h1>
      <p class="max-w-3xl text-sm leading-8 text-neutral-600">
        The table shape is ready for order detail views, status transitions, and
        Shiprocket dispatch actions once the Convex backend lands.
      </p>
    </header>

    <AdminTable
      title="Order ledger"
      description="Operational state, payment state, and shipping next-step all stay visible in one table."
      columns={["Order", "Status", "Payment", "City", "Next step"]}
      rows={orders}
    />
  </div>
</AdminLayout>
