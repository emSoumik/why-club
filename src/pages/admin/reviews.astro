---
import AdminTable from "@/components/admin/AdminTable.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { demoReviews } from "@/lib/demo-data";
---

<AdminLayout title="WhÿClub admin | reviews">
  <div class="space-y-8">
    <header class="space-y-3">
      <p class="text-[0.68rem] uppercase tracking-[0.35em] text-neutral-500">reviews</p>
      <h1 class="font-display text-6xl leading-[0.9] tracking-[-0.09em] text-neutral-950">Moderate only the quotes worth keeping.</h1>
      <p class="max-w-3xl text-sm leading-8 text-neutral-600">
        The review queue is meant to be editorial, not bloated. Approve strong social
        proof and keep the product link visible at the moderation layer.
      </p>
    </header>

    <AdminTable
      title="Pending reviews"
      description="Current quotes from the seeded demo content."
      columns={["Author", "Product", "Location", "Rating", "Quote"]}
      rows={demoReviews.map((review) => [
        review.author,
        review.productSlug,
        review.location,
        `${review.rating}/5`,
        review.comment,
      ])}
    />
  </div>
</AdminLayout>
