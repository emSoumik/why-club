---
import AdminTable from "@/components/admin/AdminTable.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";

const teamRows = [
  ["founder@whyclub.in", "super_admin", "Full access", "Live"],
  ["ops@whyclub.in", "admin", "Orders, products, coupons", "Pending invite"],
  ["content@whyclub.in", "editor", "Reviews and copy", "Pending invite"],
];
---

<AdminLayout title="WhÿClub admin | team">
  <div class="space-y-8">
    <header class="space-y-3">
      <p class="text-[0.68rem] uppercase tracking-[0.35em] text-neutral-500">team</p>
      <h1 class="font-display text-6xl leading-[0.9] tracking-[-0.09em] text-neutral-950">Role control stays explicit.</h1>
      <p class="max-w-3xl text-sm leading-8 text-neutral-600">
        The final Convex RBAC layer owns the real permissions. This page gives the
        admin surface a clear shape for invites, role promotion, and operational ownership.
      </p>
    </header>

    <AdminTable
      title="Team access"
      description="Role assignment shell for super-admin control."
      columns={["User", "Role", "Scope", "Status"]}
      rows={teamRows}
    />
  </div>
</AdminLayout>
