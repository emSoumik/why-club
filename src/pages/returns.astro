---
import SectionHeader from "@/components/storefront/SectionHeader.astro";
import StorefrontLayout from "@/layouts/StorefrontLayout.astro";
import { returnsPolicy } from "@/lib/demo-data";
---

<StorefrontLayout title="WhÿClub | returns & exchange">
  <section class="store-shell mx-auto max-w-7xl px-4 py-12 md:px-6 md:py-16">
    <SectionHeader
      eyebrow="returns"
      title="Fast policy, clear terms, no support theatre."
      body="The backend can later store these as policy records or CMS content. For now they stay seeded and visible."
    />
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        returnsPolicy.map((item) => (
          <article class="rounded-[2rem] border border-black bg-white p-6">
            <h2 class="text-2xl font-black uppercase tracking-[-0.05em] text-black">{item.title}</h2>
            <p class="mt-4 text-sm leading-8 text-neutral-600">{item.body}</p>
          </article>
        ))
      }
      <article class="rounded-[2rem] border border-black bg-black p-6 text-white">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-red-400">exchange policy</p>
        <p class="mt-4 text-sm leading-8 text-neutral-300">
          Size exchanges stay free and depend on stock availability. If the requested
          size is sold out, the operational fallback is a refund or a manual support
          resolution through the admin workflow.
        </p>
      </article>
      <article class="rounded-[2rem] border border-black bg-white p-6">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-neutral-500">what to report fast</p>
        <p class="mt-4 text-sm leading-8 text-neutral-600">
          Damaged or defective items must be reported within 48 hours with photo proof.
          This page mirrors the support logic that later plugs into ticketing or admin notes.
        </p>
      </article>
    </div>
  </section>
</StorefrontLayout>
