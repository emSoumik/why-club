---
import ReviewCard from "@/components/storefront/ReviewCard.astro";
import { ProductAddToCart } from "@/components/react/StorefrontClient";
import StorefrontLayout from "@/layouts/StorefrontLayout.astro";
import { demoReviews, getProductBySlug } from "@/lib/demo-data";
import { formatInr } from "@/lib/utils";

const slug = Astro.params.slug ?? "";
const product = getProductBySlug(slug);

if (!product) {
  Astro.response.status = 404;
}

const reviews = product
  ? demoReviews.filter((review) => review.productSlug === product.slug)
  : [];
---

<StorefrontLayout
  title={product ? `WhÿClub | ${product.title}` : "WhÿClub | product not found"}
>
  {
    product ? (
      <>
        <section class="store-shell mx-auto max-w-7xl px-4 py-12 md:px-6 md:py-16">
          <div class="grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
            <div class="overflow-hidden rounded-[2rem] border border-black bg-[#f1ece2]">
              <img src={product.images[0]} alt={product.title} class="aspect-[4/5] w-full object-cover object-top" />
            </div>
            <article class="rounded-[2rem] border border-black bg-white p-6 md:p-8">
              <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-red-600">{product.badge}</p>
              <h1 class="mt-4 max-w-4xl text-4xl font-black uppercase leading-[0.88] tracking-[-0.06em] text-black md:text-6xl">
                {product.title}
              </h1>
              <p class="mt-5 max-w-2xl text-sm leading-8 text-neutral-600">{product.description}</p>

              <div class="mt-6 flex flex-wrap items-end gap-3 border-b border-black pb-6">
                <span class="text-2xl font-black uppercase tracking-[0.04em] text-black">
                  {formatInr(product.sellingPrice)}
                </span>
                {product.sellingPrice < product.mrp && (
                  <span class="text-sm font-medium text-neutral-400 line-through">{formatInr(product.mrp)}</span>
                )}
              </div>

              <div class="mt-6 grid gap-4 md:grid-cols-2">
                <article class="rounded-[1.5rem] border border-black/10 bg-[#f7f4ef] p-5">
                  <p class="text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-neutral-500">build</p>
                  <p class="mt-3 text-sm leading-7 text-neutral-700">
                    {product.material} · {product.weightGsm} gsm · {product.fit} fit
                  </p>
                </article>
                <article class="rounded-[1.5rem] border border-black/10 bg-[#f7f4ef] p-5">
                  <p class="text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-neutral-500">inventory</p>
                  <p class="mt-3 text-sm leading-7 text-neutral-700">
                    {product.inventoryCount} pieces in demo stock
                  </p>
                </article>
              </div>

              <div class="mt-6">
                <p class="text-[0.62rem] font-semibold uppercase tracking-[0.32em] text-neutral-500">sizes</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {
                    product.sizes.map((size) => {
                      const unavailable = product.soldOutSizes.includes(size);

                      return (
                        <span
                          class:list={[
                            "rounded-full border px-4 py-2 text-[0.62rem] font-semibold uppercase tracking-[0.28em]",
                            unavailable
                              ? "border-black/5 bg-neutral-100 text-neutral-400 line-through"
                              : "border-black bg-white text-black",
                          ]}
                        >
                          {size}
                        </span>
                      );
                    })
                  }
                </div>
              </div>

              <div class="mt-6 flex flex-wrap gap-2">
                {product.tags.map((tag) => (
                  <span class="rounded-full border border-black/10 px-3 py-2 text-[0.58rem] font-semibold uppercase tracking-[0.28em] text-neutral-500">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="mt-8">
                <ProductAddToCart
                  client:load
                  productSlug={product.slug}
                  productTitle={product.title}
                  priceLabel={formatInr(product.sellingPrice)}
                  availableSizes={product.sizes}
                  soldOutSizes={product.soldOutSizes}
                  checkoutHref={`/checkout?product=${product.slug}`}
                />
              </div>
            </article>
          </div>
        </section>

        <section class="store-shell mx-auto max-w-7xl px-4 pb-16 md:px-6">
          <div class="grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
            <article class="rounded-[2rem] border border-black bg-black p-6 text-white md:p-8">
              <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-red-400">product story</p>
              <p class="mt-5 text-base leading-8 text-neutral-200 md:text-lg">
                {product.story}
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href="/returns" class="store-btn store-btn--inverse">
                  shipping & returns
                </a>
                <a href="/cart" class="store-btn store-btn--outline-light">
                  open cart
                </a>
              </div>
            </article>
            <div class="grid gap-4">
              {reviews.map((review) => <ReviewCard review={review} />)}
            </div>
          </div>
        </section>
      </>
    ) : (
      <section class="store-shell mx-auto max-w-3xl px-4 py-20 text-center md:px-6">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-neutral-500">404</p>
        <h1 class="mt-4 text-5xl font-black uppercase tracking-[-0.06em] text-black">product not found</h1>
      </section>
    )
  }
</StorefrontLayout>
