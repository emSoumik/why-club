---
import { StorefrontClientBridge } from "@/components/react/StorefrontClient";
import SiteFooter from "@/components/storefront/SiteFooter.astro";
import SiteHeader from "@/components/storefront/SiteHeader.astro";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "WhÿClub demo storefront" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#121212" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-display: "Inter", sans-serif;
        --font-body: "Inter", sans-serif;
      }

      body {
        font-family: var(--font-body);
      }

      .font-display {
        font-family: var(--font-display);
      }
    </style>
  </head>
  <body class="text-neutral-950 antialiased">
    <div class="relative min-h-screen overflow-x-hidden">
      <div class="pointer-events-none absolute inset-0 opacity-60 store-grid-line"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[36rem] bg-[radial-gradient(circle_at_top,rgba(224,0,0,0.12),transparent_48%)]"></div>
      <SiteHeader />
      <main class="relative"><slot /></main>
      <SiteFooter />
      <StorefrontClientBridge client:load />
    </div>
  </body>
</html>
