---
interface Props {
  eyebrow: string;
  title: string;
  body?: string;
}

const { eyebrow, title, body } = Astro.props;
---

<div class="flex flex-col gap-4 border-b border-black pb-5 md:flex-row md:items-end md:justify-between">
  <div class="max-w-3xl">
    <p class="text-[0.62rem] font-semibold uppercase tracking-[0.34em] text-red-600">{eyebrow}</p>
    <h2 class="mt-3 max-w-3xl text-3xl font-black uppercase tracking-[-0.06em] text-black md:text-5xl">
      {title}
    </h2>
  </div>
  {body && <p class="max-w-xl text-sm leading-7 text-neutral-600">{body}</p>}
</div>
