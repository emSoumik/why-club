---
interface Props {
  label: string;
  value: string;
  note: string;
}

const { label, value, note } = Astro.props;
---

<article class="rounded-[1.75rem] border border-black/10 bg-white p-6 shadow-[0_24px_80px_rgba(15,23,42,0.05)]">
  <p class="text-[0.68rem] uppercase tracking-[0.3em] text-neutral-500">{label}</p>
  <div class="mt-4 font-display text-4xl tracking-[-0.08em] text-neutral-950">{value}</div>
  <p class="mt-3 text-sm leading-6 text-neutral-600">{note}</p>
</article>
