---
interface Props {
  title: string;
  description: string;
  columns: string[];
  rows: string[][];
}

const { title, description, columns, rows } = Astro.props;
---

<section class="rounded-[1.75rem] border border-black/10 bg-white shadow-[0_24px_80px_rgba(15,23,42,0.05)]">
  <div class="border-b border-black/10 px-6 py-5">
    <h2 class="font-display text-3xl tracking-[-0.06em] text-neutral-950">{title}</h2>
    <p class="mt-2 max-w-2xl text-sm leading-7 text-neutral-600">{description}</p>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full text-left">
      <thead>
        <tr class="border-b border-black/10 bg-neutral-50/80 text-[0.68rem] uppercase tracking-[0.3em] text-neutral-500">
          {columns.map((column) => <th class="px-6 py-4 font-medium">{column}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr class="border-b border-black/5 last:border-b-0">
              {row.map((cell) => (
                <td class="px-6 py-4 text-sm leading-7 text-neutral-700">{cell}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
